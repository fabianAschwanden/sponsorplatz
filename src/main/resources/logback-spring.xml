<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="false">

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!--
        In-Memory-Ringbuffer der letzten ERROR-Events — wird im Ops-Dashboard
        /admin/system angezeigt. Profil-unabhängig, daher ausserhalb von
        springProfile-Blöcken.
    -->
    <appender name="RECENT_ERRORS" class="ch.sponsorplatz.ops.RecentErrorsAppender"/>

    <!--
        Sentry-Logback-Appender: forwardet WARN+ERROR an Sentry/Glitchtip.
        - minimumEventLevel=ERROR: nur Errors werden als Events angelegt
        - minimumBreadcrumbLevel=INFO: INFO+ landen als Breadcrumbs am Event
        - Ohne gesetzten sentry.dsn ist der Sentry-SDK-Client im No-Op-Modus —
          dieser Appender feuert dann ins Leere statt zu crashen.
    -->
    <appender name="SENTRY" class="io.sentry.logback.SentryAppender">
        <minimumEventLevel>ERROR</minimumEventLevel>
        <minimumBreadcrumbLevel>INFO</minimumBreadcrumbLevel>
    </appender>

    <!--
        JSON-Appender für prod/cloud-free: strukturierte Logs mit logstash-encoder.
        Trace-ID aus MDC wird automatisch als Feld mitgeliefert.
    -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>method</includeMdcKeyName>
            <includeMdcKeyName>uri</includeMdcKeyName>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version>
            </fieldNames>
        </encoder>
    </appender>

    <!-- Dev/Test: menschenlesbare Console-Ausgabe -->
    <springProfile name="dev,test,default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="RECENT_ERRORS"/>
            <appender-ref ref="SENTRY"/>
        </root>
        <logger name="ch.sponsorplatz" level="DEBUG"/>
    </springProfile>

    <!-- Prod/Cloud-free: JSON-Ausgabe für Log-Aggregation -->
    <springProfile name="prod,cloud-free">
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="RECENT_ERRORS"/>
            <appender-ref ref="SENTRY"/>
        </root>
        <logger name="ch.sponsorplatz" level="INFO"/>
    </springProfile>

</configuration>
