{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mvn: clean",
      "type": "shell",
      "command": "mvn",
      "args": ["clean"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true }
    },
    {
      "label": "mvn: compile",
      "type": "shell",
      "command": "mvn",
      "args": ["compile"],
      "group": "build"
    },
    {
      "label": "mvn: test",
      "type": "shell",
      "command": "mvn",
      "args": ["test"],
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "mvn: package",
      "type": "shell",
      "command": "mvn",
      "args": ["clean", "package"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true }
    },
    {
      "label": "mvn: verify (incl. coverage)",
      "type": "shell",
      "command": "mvn",
      "args": ["clean", "verify"],
      "group": "build"
    },
    {
      "label": "spring-boot:run (dev)",
      "type": "shell",
      "command": "mvn",
      "args": ["spring-boot:run", "-Dspring-boot.run.profiles=dev"],
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "docker: compose up (postgres + mailhog)",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "up", "-d", "postgres", "mailhog"],
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "docker: compose down",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "down"],
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "docker: app starten (build + run)",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "--profile", "app", "up", "--build"],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    }
  ]
}
